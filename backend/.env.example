# ─── Database ────────────────────────────────────────────────────────────────
DB_USER="fleetflow_user"
DB_PASS="your_secure_password"
DB_NAME="fleetflow_db"
DB_HOST="postgres"
DB_PORT="5431"

# Note: Prisma reads the string natively, and docker-compose dynamically interpolates the string.
# When running locally (without docker), change DB_HOST to "localhost".
DATABASE_URL="postgresql://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# A secure, random string (e.g. generated via `openssl rand -base64 32`)
JWT_SECRET="your_jwt_secret_key"
JWT_EXPIRES_IN="8h"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── Email (Nodemailer) — for license-expiry cron ────────────────────────────
# Setup instructions for SMTP_PASS (Gmail App Password):
# 1. Go to Google Account > Security > 2-Step Verification > App passwords
# 2. Generate a new app password and paste it below (without spaces)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="alerts@yourdomain.com"
SMTP_PASS="your_app_password"
SMTP_FROM="FleetFlow Alerts <alerts@yourdomain.com>"

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"
